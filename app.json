      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "האפליקציה צריכה גישה לגלריה שלך כדי לנתח תלושי שכר.",
        "NSCameraUsageDescription": "האפליקציה צריכה גישה למצלמה כדי לצלם תלושי שכר."
      }
    },
    "android": {
      "package": "com.xpera.netto",
