        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "האפליקציה צריכה גישה לגלריה שלך כדי לנתח תלושי שכר.",
          "cameraPermission": "האפליקציה צריכה גישה למצלמה כדי לצלם תלושי שכר."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "netto-f102a"
